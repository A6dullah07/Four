{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "message": {
      "type": "string",
      "maxLength": 5000
    },
    "sender": {
      "type": "string",
      "enum": [
        "user",
        "assistant"
      ]
    },
    "session_id": {
      "type": "string"
    }
  },
  "required": [
    "message",
    "sender"
  ]
}